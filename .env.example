# ============================================================
# Authopic Technologies PLC — Environment Configuration
# ============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values for LOCAL or PRODUCTION below.
# 3. NEVER commit .env to version control.
# ============================================================

APP_ENV=local            # local | production
APP_DEBUG=true           # true in dev, FALSE in production

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
DB_HOST=localhost
DB_NAME=authopic_db      # local dev example: dev_group
DB_USER=root             # production: use a dedicated DB user
DB_PASS=                 # strong password in production

# ------------------------------------------------------------
# Site  (no trailing slash)
# ------------------------------------------------------------
# LOCAL:      http://localhost/ANONYMOUSDEV
# PRODUCTION: https://authopic.com
SITE_URL=http://localhost/ANONYMOUSDEV
SITE_NAME=Authopic Technologies PLC

# ------------------------------------------------------------
# Session
# ------------------------------------------------------------
SESSION_NAME=Authopic_SESSION

# ------------------------------------------------------------
# Email / SMTP
# ------------------------------------------------------------
MAIL_ENABLED=false       # true in production
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
MAIL_FROM_NAME=Authopic Technologies PLC
MAIL_FROM_EMAIL=noreply@authopic.com

# ============================================================
# PRODUCTION .env example
# ============================================================
# APP_ENV=production
# APP_DEBUG=false
# DB_HOST=localhost
# DB_NAME=authopic_db
# DB_USER=authopic_user
# DB_PASS=your_strong_db_password
# SITE_URL=https://authopic.com
# SITE_NAME=Authopic Technologies PLC
# MAIL_ENABLED=true
# MAIL_HOST=mail.authopic.com
# MAIL_PORT=587
# MAIL_ENCRYPTION=tls
# MAIL_USER=noreply@authopic.com
# MAIL_PASS=your_mail_password
# MAIL_FROM_NAME=Authopic Technologies PLC
# MAIL_FROM_EMAIL=noreply@authopic.com
