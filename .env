# ============================================================
# Authopic Technologies PLC — Environment Configuration
# LOCAL DEVELOPMENT
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

APP_ENV=local
APP_DEBUG=true

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
DB_HOST=localhost
DB_NAME=dev_group
DB_USER=root
DB_PASS=0000

# ------------------------------------------------------------
# Site
# ------------------------------------------------------------
# No trailing slash. For local XAMPP/WAMP use e.g. http://localhost/ANONYMOUSDEV
SITE_URL=https://authopic.test/
SITE_NAME=Authopic Technologies PLC

# ------------------------------------------------------------
# Session
# ------------------------------------------------------------
SESSION_NAME=Authopic_SESSION

# ------------------------------------------------------------
# Email (SMTP) — set MAIL_ENABLED=true when ready
# ------------------------------------------------------------
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USER=
MAIL_PASS=
MAIL_FROM_NAME=Authopic Technologies PLC
MAIL_FROM_EMAIL=noreply@authopic.com
